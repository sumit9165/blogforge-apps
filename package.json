{
  "name": "blogforge",
  "version": "1.0.0",
  "description": "Full-stack blogging platform — React + Vite + Express + MySQL",
  "private": true,
  "scripts": {
    "install:all":    "npm install --prefix backend && npm install --prefix frontend",
    "migrate":        "npm run migrate --prefix backend",
    "dev:backend":    "npm run dev --prefix backend",
    "dev:frontend":   "npm run dev --prefix frontend",
    "dev":            "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend",
    "start:backend":  "npm start --prefix backend",
    "preview":        "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
