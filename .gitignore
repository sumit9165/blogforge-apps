# ============================================================
# BlogForge — .gitignore
# ============================================================

# ── Node / Dependencies ──────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# ── Environment Files (NEVER commit these) ───────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*/.env
*/.env.local
!.env.example
!*/.env.example
backend/.env
frontend/.env

# ── Build Output ─────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
build/
dist/
out/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
backend/logs/
combined.log
error.log

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Runtime / Process ────────────────────────────────────────
*.pid
*.seed
*.pid.lock
pids/

# ── Docker volumes (generated data) ─────────────────────────
docker-volumes/
mysql-data/

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ─────────────────────────────────────────────────────
*.tgz
*.tar.gz
.cache/
.parcel-cache/
.turbo/
